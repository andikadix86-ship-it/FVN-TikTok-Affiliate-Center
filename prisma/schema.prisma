generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum ProductSource {
  DEMO
  MANUAL
  CSV_IMPORT
  REAL_API
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
}

enum ProviderMode {
  AI
  TEMPLATE
}

enum ContentStatus {
  DRAFT
  READY
  POSTED
  ARCHIVED
}

enum TikTokOAuthLogStatus {
  SUCCESS
  ERROR
}

model Product {
  id               String        @id @default(cuid())
  productName      String
  platform         String        @default("TikTok")
  category         String
  price            Decimal       @db.Decimal(10, 2)
  commissionRate   Decimal       @db.Decimal(5, 2)
  salesScore       Int
  soldCount        Int?
  rating           Decimal?      @db.Decimal(3, 2)
  reviewCount      Int?
  competitionLevel String
  productUrl       String?
  imageUrl         String?
  targetAudience   String?
  problemSolved    String?
  mainBenefit      String?
  demoIdea         String?
  source           ProductSource @default(MANUAL)
  notes            String?
  score            Int
  recommendation   String
  contentPacks     ContentPack[]
  campaigns        Campaign[]
  postedContents   PostedContent[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([source])
  @@index([score])
}

model ContentPack {
  id                 String       @id @default(cuid())
  productId          String
  product            Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  contentTitle       String?
  contentMode        String?
  targetAudience     String?
  tone               String?
  productBrief       Json?
  productInsight     String?      @db.Text
  mainSellingPoint   String?      @db.Text
  targetAudienceMatch String?     @db.Text
  hooks              Json
  selectedHook       String?      @db.Text
  script15s          String       @db.Text
  script30s          String       @db.Text
  script60s          String?      @db.Text
  scenePlan          Json
  storyboard         Json?
  uploadedMediaAssets Json?
  sceneMediaAssignments Json?
  subtitleSettings   Json?
  fontSettings       Json?
  musicSettings      Json?
  voiceOverSettings  Json?
  previewVideoMeta   Json?
  voiceOverDraft     String?      @db.Text
  caption            String       @db.Text
  captionShort       String?      @db.Text
  captionMedium      String?      @db.Text
  captionStorytelling String?     @db.Text
  hashtags           Json
  cta                String       @db.Text
  ctaSoft            String?      @db.Text
  ctaDirect          String?      @db.Text
  ctaKeranjangKuning String?      @db.Text
  safeClaimChecklist Json
  complianceChecklist Json?
  nanoBananaPrompts  Json?
  veo3Prompts        Json?
  editingNotes       Json?
  postingNotes       Json?
  talkingPoints      Json?
  notes              String?      @db.Text
  status             ContentStatus @default(DRAFT)
  providerMode       ProviderMode @default(TEMPLATE)
  campaigns          Campaign[]
  postedContents     PostedContent[]
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  @@index([productId])
  @@index([status])
  @@index([createdAt])
}

model Campaign {
  id          String                @id @default(cuid())
  productId   String
  product     Product               @relation(fields: [productId], references: [id], onDelete: Cascade)
  contentPackId String?
  contentPack ContentPack?          @relation(fields: [contentPackId], references: [id], onDelete: SetNull)
  name        String
  durationDays Int
  goal        String
  status      CampaignStatus        @default(DRAFT)
  dailyPlan   Json
  performance CampaignPerformance[]
  postedContents PostedContent[]
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@index([productId])
  @@index([contentPackId])
  @@index([status])
}

model CampaignPerformance {
  id         String   @id @default(cuid())
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  dayNumber  Int
  views      Int      @default(0)
  likes      Int      @default(0)
  comments   Int      @default(0)
  shares     Int      @default(0)
  clicks     Int      @default(0)
  orders     Int      @default(0)
  revenue    Decimal  @default(0) @db.Decimal(10, 2)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([campaignId, dayNumber])
  @@index([campaignId])
}

model PostedContent {
  id              String       @id @default(cuid())
  contentPackId   String
  contentPack     ContentPack  @relation(fields: [contentPackId], references: [id], onDelete: Cascade)
  campaignId      String?
  campaign        Campaign?    @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  campaignDayNumber Int?
  productId       String
  product         Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  tiktokAccountId String?
  tiktokAccount   TikTokAccount? @relation(fields: [tiktokAccountId], references: [id], onDelete: SetNull)
  tiktokVideoUrl  String
  postedAt        DateTime
  accountUsed     String?
  notes           String?      @db.Text
  views           Int          @default(0)
  likes           Int          @default(0)
  comments        Int          @default(0)
  shares          Int          @default(0)
  saves           Int          @default(0)
  clicks          Int          @default(0)
  orders          Int          @default(0)
  revenue         Decimal      @default(0) @db.Decimal(10, 2)
  archived        Boolean      @default(false)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([contentPackId])
  @@index([campaignId])
  @@index([productId])
  @@index([postedAt])
  @@index([archived])
}

model TikTokAccount {
  id                    String   @id @default(cuid())
  openId                String   @unique
  displayName           String?
  avatarUrl             String?
  profileDeepLink       String?
  accessTokenEncrypted  String?
  refreshTokenEncrypted String?
  tokenExpiresAt        DateTime?
  refreshExpiresAt      DateTime?
  tokenStatus           String   @default("not_stored")
  scopeStatus           String   @default("unknown")
  lastSyncStatus        String   @default("not_synced")
  postedContents        PostedContent[]
  connectedAt           DateTime @default(now())
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model TikTokOAuthLog {
  id          String              @id @default(cuid())
  status      TikTokOAuthLogStatus
  errorCode   String?
  message     String
  safeDetails Json?
  createdAt   DateTime            @default(now())

  @@index([status])
  @@index([createdAt])
}

model AppSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
